    "lucide-react": "^0.577.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "playwright-core": "^1.60.0",
    "posthog-js": "^1.373.2",
    "posthog-node": "^5.33.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
