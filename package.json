    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/qstash": "^2.10.1",
    "@x402/fetch": "^2.11.0",
    "agentmail": "^0.5.2",
    "ai": "^6.0.177",
